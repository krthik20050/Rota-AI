# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Graphify analysis cache
graphify-out/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# Binaries and build artifacts
build/
dist/
*.exe
*.msi
*.dmg
*.spec
*.pkg

# Venv hash cache (auto-generated by run.bat)
.venv/.req_hash

# Runtime data (logs, temp appdata, local state, test DBs)
desktop/logs/
logs/
tmp-appdata/
*.log
*.db
_test_sessions.db

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Agent/AI tooling (development-only, not app code)
.claude/
.claude-flow/
.agents/
_bmad/
.swarm/
.cursor/
.planning/
.codex/

# Local machine config (contains personal paths)
.claude/settings.local.json

# Web projects moved to dedicated repo path
# website/  -- DO NOT ignore; website is deployed from this repo via vercel.json
waitlist-system/

# Misc scratch notes / planning docs (not user-readable)
newchat.md
github_research.md
Rotareview.md
AGENTS.md

# Diagnostic / trace files — may contain env-var status, paths, or key info
diagnostic_trace*.py
diagnostic_trace_results*.json

# PyInstaller spec files — contain absolute local paths
*.spec

# Scratch / working files
scratch/
PLAN.md
DESIGN.md

# Auto-generated codebase maps (can contain sensitive path info)
CODEBASE_MAP.md

# Example launcher (local-only)
desktop-launcher.example.bat
