# Rota AI — Environment Configuration
# Copy this file to .env and fill in your own API keys.
# NEVER commit .env to version control.

# Google Gemini API Key (for AI text cleanup)
# Get yours at: https://aistudio.google.com/app/apikey
# Starts with: AIza...
GEMINI_API_KEY=

# Groq API Key (for cloud transcription fallback)
# Get yours at: https://console.groq.com/keys
# Starts with: gsk_...
GROQ_API_KEY=
